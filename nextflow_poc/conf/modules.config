process {
    withName: 'CONVERSION_EUBIBRIDGE' {
        publishDir =[
         path: {"${params.outdir}"}, 
         mode: 'copy', 
         pattern: "*.zarr"  
        ]
        ext.args =  [
            "--verbose",
            "--region_size_mb", "${params.region_size_mb}",
            "--max_concurrency", "${params.max_concurrency}"
        ].join(' ').trim()
    }
    withName: 'CONVERSION_EUBIBRIDGE_CONCATENATION' {
        publishDir =[
         path: {"${params.outdir}"}, 
         mode: 'copy', 
         pattern: "*.zarr"  
        ]
        ext.args =  [
            "--verbose",
            "--skip_dask",
            "--region_size_mb", "${params.region_size_mb}",
            "--max_concurrency", "${params.max_concurrency}",
            "--channel_tag" , "${params.channel_tag}",
            "--z_tag", "${params.z_tag}",
            "--concatenation_axes",  "${params.concatenation_axes}"
        ].join(' ').trim()
    }
}