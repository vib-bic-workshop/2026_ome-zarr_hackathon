process {
    withName: 'CONVERSION_EUBIBRIDGE' {
        publishDir =[
         path: {"${params.outdir}"}, 
         mode: 'copy', 
         pattern: "*.zarr"  
        ]
        ext.args =  [
            "--verbose",
            "--region_size_mb", "${params.region_size_mb}",
            "--max_concurrency", "${params.max_concurrency}"
        ].join(' ').trim()
    }
}